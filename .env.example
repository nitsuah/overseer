# Environment Variables Template

# Copy to .env.local and fill with real values.

# GitHub
GITHUB_TOKEN=replace-with-personal-access-token
GITHUB_SYSTEM_USERNAME=nitsuah
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret

# Database (Neon/Supabase/Postgres)
DATABASE_URL=postgresql://neondb_owner:replace-with-password@your-neon-host:5432/your-database
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Netlify
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=

# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Overseer

# Feature flags
OVERSEER_DEBUG=false

# Gemini API Key
GEMINI_API_KEY=replace-with-gemini-api-key....
# Gemini model defaults to models/gemini-2.5-flash with automatic discovery/fallback.
# Optional: override the model used by the application.
# GEMINI_MODEL_NAME=models/gemini-2.5-flash

# Optional: OpenAI fallback (priority 2)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview  # Optional, defaults to this

# Optional: Anthropic fallback (priority 3)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022  # Optional, defaults to this

# Optional: BYOK overrides for per-provider keys (takes precedence over default keys)
# BYOK_GEMINI_API_KEY=replace-with-user-gemini-key
# BYOK_OPENAI_API_KEY=replace-with-user-openai-key
# BYOK_ANTHROPIC_API_KEY=replace-with-user-anthropic-key

# Optional: provider routing controls
# AI_PROVIDER_ORDER=gemini,openai,anthropic
# AI_DEPRIORITIZE_GEMINI_ON_QUOTA=true
# GEMINI_QUOTA_EXCEEDED=false