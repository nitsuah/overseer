{
  "name": "overseer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --config config/eslint.config.mjs",
    "setup-db": "tsx scripts/setup-db.ts",
    "migrate": "tsx scripts/migrate.ts",
    "check-schema": "tsx scripts/check-schema.ts",
    "test-query": "tsx scripts/test-query.ts",
    "test-gemini": "tsx scripts/test-gemini.ts",
    "test-gemini-direct": "tsx scripts/test-gemini-direct.ts",
    "test-gemini-health": "node scripts/test-gemini-health.mjs",
    "find-gemini-models": "node scripts/test-model-names.mjs",
    "list-gemini-models": "tsx scripts/list-models.ts",
    "test": "vitest --config config/vitest.config.ts",
    "prepare": "husky || true",
    "postinstall": "node -e \"const fs=require('fs'),f='node_modules/gray-matter/lib/engines.js';try{let c=fs.readFileSync(f,'utf8');c=c.replace('yaml.safeLoad.bind(yaml)','(yaml.load||yaml.safeLoad).bind(yaml)').replace('yaml.safeDump.bind(yaml)','(yaml.dump||yaml.safeDump).bind(yaml)');fs.writeFileSync(f,c);}catch(e){}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.1.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.42.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@netlify/functions": "^5.3.0",
    "@netlify/plugin-nextjs": "^5.15.11",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "baseline-browser-mapping": "^2.10.37",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.0.14"
  },
  "overrides": {
    "postcss": "8.5.15",
    "js-yaml": "^4.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --config config/eslint.config.mjs",
      "vitest related --run --config config/vitest.config.ts"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
